$C = "Common.ui";
$Sounds = "Sounds.ui";

Group {
  LayoutMode: Full;

  Slider #Esc {
    Value: 50;
    Min: 0;
    Max: 100;
    Style: SliderStyle();
  }

  Group {
    LayoutMode: Bottom;

    $C.@DecoratedContainer {
      @CloseButton = true;
      Anchor: (Left: 10, Right: 10, Bottom: 10);
      HitTestVisible: true;

      #Title {
        Group {
          Anchor: (Left: 20);
          LayoutMode: Left;

          Group #TimelinesContainer {
            DropdownBox #Timelines {
            }
          }

          Button #ZoomOut {
            Anchor: (Width: 20, Height: 20, Left: 10);
            TooltipText: %replay.zoomOut;
            Style: (
              Default: (
                Background: (TexturePath: "Assets/ZoomOut.png"),
              ),
              Hovered: (
                Background: (TexturePath: "Assets/ZoomOutHovered.png"),
              ),
              Pressed: (
                Background: (TexturePath: "Assets/ZoomOutPressed.png"),
              ),
            );
          }

          Button #ZoomIn {
            Anchor: (Width: 20, Height: 20, Left: 10);
            TooltipText: %replay.zoomIn;
            Style: (
              Default: (
                Background: (TexturePath: "Assets/ZoomIn.png"),
              ),
              Hovered: (
                Background: (TexturePath: "Assets/ZoomInHovered.png"),
              ),
              Pressed: (
                Background: (TexturePath: "Assets/ZoomInPressed.png"),
              ),
            );
          }
        }

        Group {
          Anchor: (Full: 0);
          LayoutMode: Center;

          ActionButton #Pause {
            KeyBindingLabel: %replay.pause;
          }
        }
        
        Group {
          Anchor: (Right: 20);
          LayoutMode: Right;
        }
      }

      #Content {
        LayoutMode: Left;

        Group #PropertiesHeaderContainer {
          LayoutMode: Top;
          Anchor: (Width: 140);
          FlexWeight: 0;
          
          Group {
            LayoutMode: Full;
            Anchor: (Horizontal: 0, Height: 26, Top: 10);

            DropdownBox #AddProperty {
              Anchor: (Full: 0);
              Value: "";
              Style: (...$C.@DefaultDropdownBoxStyle, EntriesInViewport: 3, ArrowWidth: 0, LabelStyle: (TextColor: #000000(0)));

              DropdownEntry {
                Value: "camera";
                Text: %replay.camera;
              }

              DropdownEntry {
                Value: "speed";
                Text: %replay.speed;
              }
            }

            Label {
              Text: %replay.plusAddProperty;
              Anchor: (Full: 0);
              Style: (FontSize: 14, TextColor: #ccd8e8, Alignment: Center);
            }
          }

          Group #PropertiesHeader {
            LayoutMode: Top;
            Anchor: (Top: 8);

            Group {
              Anchor: (Horizontal: 0, Height: 30, Top: 5);
              LayoutMode: Left;

              Button #Remove {
                Anchor: (Width: 12, Height: 12, Top: 9);
                TooltipText: %replay.removeProperty;
                Style: (
                  Default: (
                    Background: (TexturePath: "Assets/Close.png"),
                  ),
                  Hovered: (
                    Background: (TexturePath: "Assets/CloseHovered.png"),
                  ),
                  Pressed: (
                    Background: (TexturePath: "Assets/ClosePressed.png"),
                  ),
                );
              }

              Group {
                FlexWeight: 1;
                Anchor: (Left: 6);
                Background: (TexturePath: "Common/InputBinding.png", Border: 6);
                LayoutMode: Left;

                Label {
                  FlexWeight: 1;
                  Text: %replay.camera;
                  Anchor: (Vertical: 0, Left: 6);
                  Style: (FontSize: 14, TextColor: #ccd8e8, VerticalAlignment: Center);
                }

                Button #AddKeyframe {
                  Anchor: (Width: 20, Height: 20, Right: 6, Top: 5);
                  TooltipText: %replay.addKeyframe;
                  Style: (
                    Default: (
                      Background: (TexturePath: "Assets/ButtonKeyframePlus.png"),
                    ),
                    Hovered: (
                      Background: (TexturePath: "Assets/ButtonKeyframePlusHovered.png"),
                    ),
                    Pressed: (
                      Background: (TexturePath: "Assets/ButtonKeyframePlusPressed.png"),
                    ),
                  );
                }
              }
            }
          }
        }

        Group #TimelineContainer {
          LayoutMode: LeftScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          FlexWeight: 1;
          
          Group #Timeline {
            LayoutMode: Top;
            Padding: (Horizontal: 30, Top: 10, Bottom: 20);

            Group #TimeScale {
              LayoutMode: Top;

              Group #Timestamps {
                Anchor: (Left: -18);
                LayoutMode: Full;
              }

              Group #Ticks {
                LayoutMode: Full;
              }
            }

            $C.@Slider #Playhead {
              Value: 50;
              Min: 0;
              Max: 100;
              Style: SliderStyle(
                Handle: "Assets/Playhead.png",
                HandleWidth: 16,
                HandleHeight: 16,
                Sounds: (
                  MouseHover: (SoundPath: $Sounds.@ButtonsLightHover, Volume: 6)
                )
              );
            }

            Group #Properties {
              LayoutMode: Top;

              Group {
                Anchor: (Height: 30, Top: 5);

                LayoutMode: Full;
                Background: #0a0b0c;
                
                Button #Keyframe1 {
                  Anchor: (Width: 16, Height: 16, Left: 60);

                  Style: (
                    Default: (
                      Background: (TexturePath: "Assets/Keyframe.png"),
                    ),
                    Hovered: (
                      Background: (TexturePath: "Assets/KeyframeHovered.png"),
                    ),
                    Pressed: (
                      Background: (TexturePath: "Assets/KeyframePressed.png"),
                    ),
                  );
                }
                
                Button #Keyframe2 {
                  Anchor: (Width: 16, Height: 16, Left: 160);

                  Style: (
                    Default: (
                      Background: (TexturePath: "Assets/Keyframe.png"),
                    ),
                    Hovered: (
                      Background: (TexturePath: "Assets/KeyframeHovered.png"),
                    ),
                    Pressed: (
                      Background: (TexturePath: "Assets/KeyframePressed.png"),
                    ),
                  );
                }
              }
            }
          }

          Group #PlaytailLayout {
            LayoutMode: Full;
            
            Group #Playtail {
              Background: #992f2b(0.8);
            }
          }
        }
      }
    }
  }
}