$C = "Common.ui";

Group {
  LayoutMode: MiddleCenter;

  $C.@DecoratedContainer {
    Anchor: (Width: 800);

    #Title {
      $C.@Title { @Text = %replay.saveReplay; }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 30);

      Label {
        Style: (FontSize: 20);
        Text: %replay.replayName;
      }

      TextField #Input {
        Style: $C.@DefaultInputFieldStyle;
        Background: $C.@InputBoxBackground;
        Anchor: (Top: 5, Left: 0, Right: 0, Height: 50);
        Padding: (Full: 10);
        PlaceholderText: "Name...";
      }

      Group {
        LayoutMode: Left;
        Anchor: (Top: 30);

        $C.@CancelTextButton #Discard {
          @Text = %replay.discard;
          FlexWeight: 1;
        }

        Group {
          Anchor: (Width: 10);
        }

        $C.@TextButton #Save {
          @Text = %replay.save;
          FlexWeight: 1;
        }
      }
    }
  }
}